# ── Required: Supabase connection (must stay in env vars) ─────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Optional: service role key bypasses RLS
# SUPABASE_SERVICE_KEY=your-service-role-key

# ── Required: Session signing (stays in env vars, change to force all logouts) ─
SESSION_SECRET=generate-a-long-random-string-here

# ── Your deployment URL (shown on Settings page for easy copy) ─────────────────
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# ── Fallback secrets (used only if Supabase config table row is empty) ─────────
# Once you set these via the Settings page in the dashboard, these are ignored.
CLOUD_API_KEY=your-current-cloud-api-key
DASHBOARD_PASSWORD=your-current-dashboard-password
FREE_CURRENCY_API_KEY=your-freecurrencyapi-key
